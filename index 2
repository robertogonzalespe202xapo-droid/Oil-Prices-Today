<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oil Tracker Pro | Investing Sync</title>
    <link href="https://fonts.cdnfonts.com/css/ds-digital" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/odometer.js/0.4.7/themes/odometer-theme-default.css">
    
    <style>
        :root { --neon-green: #39FF14; --neon-red: #ff3131; --bg-dark: #000b14; }
        body { background: var(--bg-dark); color: #fff; font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .container { background: #000; padding: 35px; border-radius: 30px; border: 1px solid #111; text-align: center; width: 360px; box-shadow: 0 0 100px rgba(0,0,0,1); }
        h1 { font-size: 0.65rem; color: #444; margin: 0 0 30px; letter-spacing: 5px; text-transform: uppercase; }
        .card { margin-bottom: 25px; padding: 20px; background: #050505; border-radius: 20px; border: 1px solid #0a0a0a; border-top: 1px solid #111; }
        .label { font-size: 0.7rem; color: #5bc0de; font-weight: 900; letter-spacing: 2px; }
        .odometer-wrapper { display: flex; align-items: center; justify-content: center; margin-top: 10px; min-height: 85px; }
        .odometer { font-family: 'DS-Digital', monospace !important; font-size: 4.2rem; font-weight: bold; }
        .up { color: var(--neon-green); text-shadow: 0 0 15px rgba(57, 255, 20, 0.2); }
        .down { color: var(--neon-red); text-shadow: 0 0 15px rgba(255, 49, 49, 0.2); }
        .percent { font-family: 'Courier New', monospace; font-size: 1.1rem; margin-left: 12px; font-weight: bold; }
        .status-bar { font-size: 0.55rem; color: #222; margin-top: 25px; display: flex; justify-content: space-between; border-top: 1px solid #0a0a0a; padding-top: 15px; }
        .live-dot { height: 6px; width: 6px; background: #111; border-radius: 50%; display: inline-block; margin-right: 6px; }
        .connected .live-dot { background: var(--neon-green); box-shadow: 0 0 10px var(--neon-green); animation: pulse 1.5s infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.2; } }
    </style>
</head>
<body>

    <div class="container" id="mainContainer">
        <h1>FUTUROS BRENT/WTI JUN-26</h1>
        
        <div class="card">
            <span class="label">BRENT CRUDE (ICE)</span>
            <div class="odometer-wrapper">
                <div id="brent_price" class="odometer">00.00</div>
                <div id="brent_percent" class="percent">0.00%</div>
            </div>
        </div>

        <div class="card">
            <span class="label">WTI CRUDE (NYMEX)</span>
            <div class="odometer-wrapper">
                <div id="wti_price" class="odometer">00.00</div>
                <div id="wti_percent" class="percent">0.00%</div>
            </div>
        </div>

        <div class="status-bar">
            <span><span class="live-dot"></span> <span id="status">SYNCING REAL-TIME...</span></span>
            <span id="timestamp">--:--:--</span>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/odometer.js/0.4.7/odometer.min.js"></script>

    <script>
        const apiKey = 'd775n0hr01qtg3nfne1gd775n0hr01qtg3nfne20';
        // Tickers ajustados para máxima paridad con Investing.com
        const symbols = {
            'OANDA:BCO_USD': { priceId: 'brent_price', percentId: 'brent_percent' },
            'OANDA:WTICO_USD': { priceId: 'wti_price', percentId: 'wti_percent' }
        };

        let yesterdayCloses = {};

        async function fetchQuotes() {
            for (const [symbol, config] of Object.entries(symbols)) {
                try {
                    const response = await fetch(`https://finnhub.io/api/v1/quote?symbol=${symbol}&token=${apiKey}`);
                    const data = await response.json();
                    if (data.c) {
                        yesterdayCloses[config.priceId] = data.pc;
                        updateUI(config.priceId, data.c);
                    }
                } catch (e) { console.warn("Error de sincronización"); }
            }
        }

        const socket = new WebSocket(`wss://ws.finnhub.io?token=${apiKey}`);

        socket.addEventListener('open', () => {
            document.getElementById('mainContainer').classList.add('connected');
            document.getElementById('status').innerText = 'LIVE: INVESTING SYNC';
            Object.keys(symbols).forEach(s => socket.send(JSON.stringify({'type':'subscribe', 'symbol': s})));
            fetchQuotes();
        });

        socket.addEventListener('message', (event) => {
            const data = JSON.parse(event.data);
            if (data.type === 'trade') {
                data.data.forEach(trade => {
                    const config = symbols[trade.s];
                    if (config) updateUI(config.priceId, trade.p);
                });
            }
        });

        function updateUI(id, price) {
            const priceEl = document.getElementById(id);
            const percentEl = document.getElementById(id.replace('price', 'percent'));
            const close = yesterdayCloses[id] || price;

            priceEl.innerHTML = price.toFixed(2);
            
            const diff = ((price - close) / close) * 100;
            percentEl.innerText = `${diff > 0 ? '+' : ''}${diff.toFixed(2)}%`;
            
            if (price > close) {
                priceEl.className = 'odometer up';
                percentEl.style.color = 'var(--neon-green)';
            } else {
                priceEl.className = 'odometer down';
                percentEl.style.color = 'var(--neon-red)';
            }

            document.getElementById('timestamp').innerText = new Date().toLocaleTimeString();
        }

        // Refrescar cada 5 min para asegurar paridad con Investing
        setInterval(fetchQuotes, 300000);
    </script>
</body>
</html>
